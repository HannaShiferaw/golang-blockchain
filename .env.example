# Backend
BACKEND_PORT=8080
BACKEND_BASE_URL=http://localhost:8080

# CouchDB (ledger + world-state docs)
COUCHDB_URL=http://couchdb:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=admin
COUCHDB_DB=coffee_ledger

# Postgres (off-chain indexes / reporting)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=coffee_demo
POSTGRES_USER=coffee
POSTGRES_PASSWORD=coffee

# Demo seed
SEED_ON_START=true
